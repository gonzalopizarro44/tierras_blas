<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="nueva_factura_template" name="Crear Nueva Factura">

        <t t-call="website.layout">

            <!-- ESTILOS -->
            <style>
                :root {
                    --brand-primary: #166534;
                    --brand-primary-dark: #0f4620;
                    --brand-light: #dcfce7;
                    --brand-secondary: #6b7280;
                    --brand-bg: #f9fafb;
                    --brand-border: #e5e7eb;
                    --brand-text: #1f2937;
                    --brand-text-muted: #6b7280;
                    --brand-shadow: 0 1px 3px rgba(0,0,0,.08);
                    --brand-radius: 0.75rem;
                }

                .nf-page { 
                    background: var(--brand-bg); 
                    min-height: 100vh; 
                    padding: 2rem 0; 
                    font-family: 'Inter', sans-serif; 
                }

                .nf-card {
                    background: white;
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    padding: 2rem;
                    box-shadow: var(--brand-shadow);
                    margin-bottom: 2rem;
                }

                .nf-title { 
                    font-size: 1.5rem; 
                    font-weight: 700; 
                    margin: 0;
                    color: var(--brand-text);
                }

                .nf-section-title {
                    font-size: 1.1rem;
                    font-weight: 600;
                    color: var(--brand-primary);
                    margin-bottom: 1.5rem;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                /* STEPS WIZARD */
                .nf-steps {
                    display: flex;
                    justify-content: space-between;
                    margin-bottom: 2rem;
                    position: relative;
                }
                .nf-steps::before {
                    content: '';
                    position: absolute;
                    top: 20px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--brand-border);
                    z-index: 1;
                }
                .nf-step {
                    width: 40px;
                    height: 40px;
                    border-radius: 50%;
                    background: white;
                    border: 2px solid var(--brand-border);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 700;
                    z-index: 2;
                    position: relative;
                    transition: all 0.3s;
                    color: var(--brand-text-muted);
                }
                .nf-step.active {
                    border-color: var(--brand-primary);
                    background: var(--brand-primary);
                    color: white;
                    box-shadow: 0 0 0 4px rgba(22,101,52,0.1);
                }
                .nf-step.completed {
                    border-color: var(--brand-primary);
                    background: var(--brand-light);
                    color: var(--brand-primary);
                }
                .nf-step-content { display: none; }
                .nf-step-content.active { display: block; animation: fadeIn 0.3s ease; }

                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(10px); }
                    to { opacity: 1; transform: translateY(0); }
                }

                /* SELECTOR DE ÓRDENES */
                .nf-orden-list {
                    max-height: 400px;
                    overflow-y: auto;
                    padding-right: 0.5rem;
                }
                .nf-orden-item {
                    background: white;
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    padding: 1rem;
                    margin-bottom: 0.75rem;
                    cursor: pointer;
                    transition: all 0.2s;
                }
                .nf-orden-item:hover {
                    border-color: var(--brand-primary);
                    background: var(--brand-bg);
                }
                .nf-orden-item.selected {
                    border-color: var(--brand-primary);
                    background: var(--brand-light);
                }

                /* FORMULARIO RECEPTOR */
                .nf-form-group { margin-bottom: 1.5rem; }
                .nf-label {
                    display: block;
                    font-weight: 600;
                    font-size: 0.85rem;
                    margin-bottom: 0.5rem;
                    color: var(--brand-text);
                }
                .nf-input, .nf-select {
                    width: 100%;
                    padding: 0.75rem;
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    font-size: 0.95rem;
                }
                .nf-input:focus, .nf-select:focus {
                    outline: none;
                    border-color: var(--brand-primary);
                    box-shadow: 0 0 0 3px rgba(22,101,52,0.1);
                }

                /* TABLA PRODUCTOS */
                .nf-table { width: 100%; border-collapse: collapse; }
                .nf-table th {
                    text-align: left;
                    padding: 1rem;
                    font-size: 0.85rem;
                    text-transform: uppercase;
                    color: var(--brand-text-muted);
                    border-bottom: 2px solid var(--brand-border);
                }
                .nf-table td { padding: 1rem; border-bottom: 1px solid var(--brand-border); }
                .nf-qty-input, .nf-price-input {
                    width: 80px;
                    padding: 0.4rem;
                    border: 1px solid var(--brand-border);
                    border-radius: 0.4rem;
                    text-align: center;
                }

                /* RESUMEN */
                .nf-summary-box {
                    background: #f8fafc;
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    padding: 1.5rem;
                }
                .nf-summary-row {
                    display: flex;
                    justify-content: space-between;
                    margin-bottom: 0.75rem;
                    font-size: 0.95rem;
                }
                .nf-summary-total {
                    border-top: 2px solid var(--brand-border);
                    padding-top: 1rem;
                    margin-top: 1rem;
                    font-weight: 700;
                    font-size: 1.25rem;
                    color: var(--brand-primary);
                }

                .nf-doc-badge {
                    background: var(--brand-primary);
                    color: white;
                    padding: 0.25rem 0.75rem;
                    border-radius: 2rem;
                    font-size: 0.8rem;
                    font-weight: 700;
                }

                .nf-btn {
                    padding: 0.75rem 1.5rem;
                    border-radius: var(--brand-radius);
                    font-weight: 600;
                    transition: all 0.2s;
                    cursor: pointer;
                    border: none;
                }
                .nf-btn-primary { background: var(--brand-primary); color: white; }
                .nf-btn-primary:disabled { background: var(--brand-secondary); opacity: 0.6; }
                .nf-btn-outline { background: white; border: 1px solid var(--brand-border); color: var(--brand-text); }
            </style>

            <div class="nf-page">
                <div class="container" style="max-width: 800px;">

                    <!-- HEADER -->
                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <div>
                            <a href="/facturacion" class="text-muted small" style="text-decoration: none;">← Volver al Panel</a>
                            <h1 class="nf-title mt-1">Nueva Factura de Venta</h1>
                        </div>
                        <div class="text-end">
                            <span class="text-muted small">Emisor:</span><br/>
                            <strong>NIILDA SA (Responsable Inscripto)</strong>
                        </div>
                    </div>

                    <!-- WIZARD STEPS -->
                    <div class="nf-steps">
                        <div id="step-1-pill" class="nf-step active">1</div>
                        <div id="step-2-pill" class="nf-step">2</div>
                        <div id="step-3-pill" class="nf-step">3</div>
                        <div id="step-4-pill" class="nf-step">4</div>
                    </div>

                    <div class="nf-card">
                        
                        <!-- STEP 1: SELECCIONAR VENTA -->
                        <div id="step-1" class="nf-step-content active">
                            <h3 class="nf-section-title">📦 1. Seleccionar Orden de Venta</h3>
                            <div class="nf-orden-list">
                                <t t-if="ordenes_venta">
                                    <t t-foreach="ordenes_venta" t-as="orden">
                                        <div class="nf-orden-item" t-att-data-id="orden.id" onclick="seleccionarOrden(this)">
                                            <div class="d-flex justify-content-between">
                                                <strong><t t-esc="orden.name"/></strong>
                                                <span class="text-primary fw-bold">$<t t-esc="'%.2f' % orden.amount_total"/></span>
                                            </div>
                                            <div class="small text-muted">
                                                Cliente: <t t-esc="orden.partner_id.name"/> | 
                                                Fecha: <t t-esc="orden.date_order.strftime('%d/%m/%Y')"/>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="text-center p-4 text-muted">No hay órdenes de venta pendientes.</div>
                                </t>
                            </div>
                            <div class="mt-4 text-end">
                                <button class="nf-btn nf-btn-primary" onclick="irAStep(2)" id="btnStep1" disabled="true">Siguiente →</button>
                            </div>
                        </div>

                        <!-- STEP 2: DATOS DEL RECEPTOR -->
                        <div id="step-2" class="nf-step-content">
                            <h3 class="nf-section-title">👤 2. Datos del Receptor</h3>
                            <div class="row">
                                <div class="col-md-12 nf-form-group">
                                    <label class="nf-label">Nombre o Razón Social</label>
                                    <input type="text" id="partner_name" class="nf-input"/>
                                </div>
                                <div class="col-md-6 nf-form-group">
                                    <label class="nf-label">CUIT / DNI</label>
                                    <input type="text" id="partner_vat" class="nf-input"/>
                                </div>
                                <div class="col-md-6 nf-form-group">
                                    <label class="nf-label">Posición Fiscal</label>
                                    <select id="partner_afip_type" class="nf-select" onchange="actualizarTipoDocumento()">
                                        <option value="">Seleccionar...</option>
                                        <t t-foreach="posiciones_fiscales" t-as="pos">
                                            <option t-att-value="pos['id']"><t t-esc="pos['name']"/></option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <div class="nf-summary-box mb-3" id="doc_type_preview" style="display:none; background: #fffbeb; border-color: #fcd34d;">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="nf-doc-badge" id="badge_tipo">?</span>
                                    <span class="small" id="text_tipo">Se generará este tipo de documento.</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <button class="nf-btn nf-btn-outline" onclick="irAStep(1)">← Atrás</button>
                                <button class="nf-btn nf-btn-primary" onclick="irAStep(3)">Siguiente →</button>
                            </div>
                        </div>

                        <!-- STEP 3: DETALLE DE PRODUCTOS -->
                        <div id="step-3" class="nf-step-content">
                            <h3 class="nf-section-title">🛒 3. Detalle de Productos</h3>
                            <div class="table-responsive">
                                <table class="nf-table">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th style="width:100px">Cant.</th>
                                            <th style="width:150px">Precio Unit.</th>
                                            <th style="width:120px">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tabla_productos">
                                        <!-- Dinámico -->
                                    </tbody>
                                </table>
                            </div>
                            <div class="mt-4 d-flex justify-content-between">
                                <button class="nf-btn nf-btn-outline" onclick="irAStep(2)">← Atrás</button>
                                <button class="nf-btn nf-btn-primary" onclick="irAStep(4)">Siguiente →</button>
                            </div>
                        </div>

                        <!-- STEP 4: CONFIRMACIÓN -->
                        <div id="step-4" class="nf-step-content">
                            <h3 class="nf-section-title">✅ 4. Confirmación Final</h3>
                            <div class="nf-summary-box">
                                <div class="nf-summary-row">
                                    <span>Orden Original:</span>
                                    <strong id="sum_orden">-</strong>
                                </div>
                                <div class="nf-summary-row">
                                    <span>Tipo de Factura:</span>
                                    <strong id="sum_tipo">-</strong>
                                </div>
                                <div class="nf-summary-row">
                                    <span>Receptor:</span>
                                    <strong id="sum_receptor">-</strong>
                                </div>
                                <div class="nf-summary-row">
                                    <span>CUIT/DNI:</span>
                                    <strong id="sum_vat">-</strong>
                                </div>
                                <div class="nf-summary-total">
                                    <span>TOTAL A FACTURAR:</span>
                                    <span id="sum_total">$0.00</span>
                                </div>
                            </div>
                            <div class="mt-4 d-flex justify-content-between">
                                <button class="nf-btn nf-btn-outline" onclick="irAStep(3)">← Atrás</button>
                                <button class="nf-btn nf-btn-primary" onclick="crearFacturaFinal()" id="btnCrear">Confirmar y Crear Factura</button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- JAVASCRIPT -->
            <script type="text/javascript">
                let state = {
                    currentStep: 1,
                    orden: null,
                    partner: { id: null, name: '', vat: '', afip_type_id: null },
                    lineas: [],
                    documentType: { id: null, name: '', code: '' }
                };

                function irAStep(n) {
                    // Validaciones básicas
                    if (n > state.currentStep) {
                        if (state.currentStep === 2 &amp;&amp; (!state.partner.name || !state.partner.afip_type_id)) {
                            alert('Complete los datos del receptor');
                            return;
                        }
                    }

                    document.querySelectorAll('.nf-step-content').forEach(c => c.classList.remove('active'));
                    document.getElementById('step-' + n).classList.add('active');
                    
                    state.currentStep = n;
                    actualizarPills();
                    
                    if (n === 4) prepararResumen();
                }

                function actualizarPills() {
                    for (let i = 1; i &lt;= 4; i++) {
                        const pill = document.getElementById('step-' + i + '-pill');
                        pill.classList.remove('active', 'completed');
                        if (i === state.currentStep) pill.classList.add('active');
                        else if (i &lt; state.currentStep) pill.classList.add('completed');
                    }
                }

                function seleccionarOrden(el) {
                    const id = el.dataset.id;
                    document.querySelectorAll('.nf-orden-item').forEach(i => i.classList.remove('selected'));
                    el.classList.add('selected');
                    
                    document.getElementById('btnStep1').innerText = '⏳ Cargando...';

                    fetch('/facturacion/detalle_orden', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({jsonrpc: "2.0", method: "call", params: {orden_id: parseInt(id)}})
                    })
                    .then(r => r.json())
                    .then(data => {
                        const res = data.result;
                        if (res.success) {
                            state.orden = res.orden;
                            state.partner = res.partner;
                            state.lineas = res.lineas;
                            
                            // Pre-llenar Form Step 2
                            document.getElementById('partner_name').value = res.partner.name;
                            document.getElementById('partner_vat').value = res.partner.vat;
                            document.getElementById('partner_afip_type').value = res.partner.afip_type_id;
                            
                            // Cargar tabla Step 3
                            cargarTablaProductos();
                            
                            // Resetear tipo de documento antes de recalcular
                            state.documentType = { id: null, name: '', code: '' };
                            document.getElementById('doc_type_preview').style.display = 'none';
                            actualizarTipoDocumento();
                            
                            document.getElementById('btnStep1').disabled = false;
                            document.getElementById('btnStep1').innerText = 'Siguiente →';
                        }
                    });
                }

                function cargarTablaProductos() {
                    const tbody = document.getElementById('tabla_productos');
                    tbody.innerHTML = '';
                    state.lineas.forEach((l, index) => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${l.name}</td>
                            <td><input type="number" class="nf-qty-input" value="${l.quantity}" onchange="updateLine(${index}, 'quantity', this.value)"/></td>
                            <td><input type="number" step="0.01" class="nf-price-input" value="${l.price_unit}" onchange="updateLine(${index}, 'price_unit', this.value)"/></td>
                            <td class="fw-bold text-end">$${(l.quantity * l.price_unit).toFixed(2)}</td>
                        `;
                        tbody.appendChild(tr);
                    });
                }

                function updateLine(index, field, value) {
                    state.lineas[index][field] = parseFloat(value);
                    cargarTablaProductos();
                }

                function actualizarTipoDocumento() {
                    const afip_type_id = document.getElementById('partner_afip_type').value;
                    state.partner.afip_type_id = afip_type_id;
                    state.partner.name = document.getElementById('partner_name').value;
                    state.partner.vat = document.getElementById('partner_vat').value;

                    if (!afip_type_id) {
                        document.getElementById('doc_type_preview').style.display = 'none';
                        return;
                    }

                    fetch('/facturacion/tipos_documento', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({jsonrpc: "2.0", method: "call", params: {posicion_fiscal_receptor_id: afip_type_id}})
                    })
                    .then(r => r.json())
                    .then(data => {
                        const res = data.result;
                        if (res &amp;&amp; res.id) {
                            state.documentType = res;
                            document.getElementById('badge_tipo').innerText = res.name;
                            document.getElementById('badge_tipo').className = "nf-doc-badge";
                            document.getElementById('text_tipo').innerText = "Se generará este tipo de documento.";
                            document.getElementById('text_tipo').style.color = "inherit";
                            document.getElementById('doc_type_preview').style.display = 'block';
                        } else {
                            state.documentType = { id: null, name: 'NO DETERMINADO', code: '' };
                            document.getElementById('badge_tipo').innerText = "AVISO";
                            document.getElementById('badge_tipo').className = "nf-doc-badge bg-warning text-dark";
                            
                            // Mostrar diagnóstico si viene del backend
                            const errorMsg = (res &amp;&amp; res.name) ? res.name : "No se encontró un tipo de factura (A/B) para esta posición. Verifique la configuración de AFIP.";
                            document.getElementById('text_tipo').innerText = errorMsg;
                            document.getElementById('text_tipo').style.color = "red";
                            document.getElementById('doc_type_preview').style.display = 'block';
                        }
                    });
                }

                function prepararResumen() {
                    document.getElementById('sum_orden').innerText = state.orden ? state.orden.name : '-';
                    document.getElementById('sum_tipo').innerText = state.documentType.id ? state.documentType.name : 'NO SELECCIONADO';
                    document.getElementById('sum_tipo').style.color = state.documentType.id ? 'inherit' : 'red';
                    
                    document.getElementById('sum_receptor').innerText = document.getElementById('partner_name').value || '-';
                    document.getElementById('sum_vat').innerText = document.getElementById('partner_vat').value || '-';
                    
                    const total = state.lineas.reduce((acc, l) => acc + (l.quantity * l.price_unit), 0);
                    document.getElementById('sum_total').innerText = '$' + total.toFixed(2);
                    
                    // Bloquear botón crear si no hay tipo de documento
                    document.getElementById('btnCrear').disabled = !state.documentType.id;
                }

                function crearFacturaFinal() {
                    if (!state.documentType.id) {
                        alert('ERROR: No se ha detectado el tipo de factura (A o B). El diario lo requiere.');
                        return;
                    }
                    const btn = document.getElementById('btnCrear');
                    btn.disabled = true;
                    btn.innerHTML = '⏳ Procesando Factura...';

                    const payload = {
                        orden_id: state.orden.id,
                        partner_data: {
                            id: state.partner.id,
                            name: document.getElementById('partner_name').value,
                            vat: document.getElementById('partner_vat').value,
                            afip_type_id: parseInt(document.getElementById('partner_afip_type').value)
                        },
                        lineas: state.lineas,
                        document_type_id: state.documentType.id
                    };

                    fetch('/facturacion/crear_factura', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({jsonrpc: "2.0", method: "call", params: payload})
                    })
                    .then(r => r.json())
                    .then(data => {
                        const res = data.result;
                        if (res &amp;&amp; res.success) {
                            alert('¡Excelente! Factura creada y publicada.');
                            window.location.href = res.url;
                        } else {
                            alert('Error: ' + (res ? res.message : 'Error desconocido'));
                            btn.disabled = false;
                            btn.innerHTML = 'Confirmar y Crear Factura';
                        }
                    })
                    .catch(e => {
                        alert('Error de red');
                        btn.disabled = false;
                    });
                }
            </script>

        </t>

    </template>

</odoo>
