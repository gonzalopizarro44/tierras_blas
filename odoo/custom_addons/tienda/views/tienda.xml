<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tienda_catalog_template" name="Catálogo de Tienda">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-light">
                <!-- Hero Section -->
                <section class="s_title pt48 pb48 bg-white shadow-sm" data-snippet="s_title">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-12 text-center">
                                <h1 class="display-4 fw-bold text-primary">Nuestro Catálogo</h1>
                                <p class="lead text-muted">Explora nuestra variedad de productos. Calidad profesional a tu alcance.</p>
                                <div class="mx-auto border-top border-primary border-2 mt-3" style="width: 50px;"></div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Catalog Grid -->
                <section class="pt32 pb64">
                    <div class="container">
                        <div t-if="not products" class="text-center py-5">
                            <h3 class="text-muted">No hay productos disponibles en este momento.</h3>
                            <p>Vuelve a visitarnos pronto o contáctanos directamente.</p>
                        </div>
                        
                        <div class="row g-4 pb-5" t-if="products">
                            <t t-foreach="products" t-as="product">
                                <div class="col-12 col-md-4 col-lg-3">
                                    <div class="card h-100 border-0 shadow-sm transition-hover product-card">
                                        <!-- Product Image -->
                                        <div class="position-relative overflow-hidden">
                                            <span t-field="product.image_512" t-options="{'widget': 'image', 'preview_image': 'image_512', 'itemprop': 'image', 'class': 'card-img-top d-block mx-auto'}" style="height: 250px; object-fit: cover;"/>
                                        </div>
                                        
                                        <!-- Card Body -->
                                        <div class="card-body d-flex flex-column p-4">
                                            <h5 class="card-title fw-bold mb-2 text-dark" t-field="product.name"/>
                                            <p class="card-text text-muted small flex-grow-1" t-field="product.description_sale" t-options="{'widget': 'text'}"/>
                                            
                                            <div class="mt-4 pt-3 border-top">
                                                <button type="button" 
                                                        class="btn btn-outline-success w-100 fw-bold d-flex align-items-center justify-content-center btn-whatsapp-catalog" 
                                                        t-att-data-product-name="product.name"
                                                        onclick="return window.contactWhatsApp(this)">
                                                    <i class="fa fa-whatsapp me-2 fs-5"/>
                                                    Solicitar Cotización
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>