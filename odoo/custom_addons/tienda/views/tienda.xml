<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tienda_catalog_template" name="Catálogo de Tienda">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <!-- Header Estilo Panel -->
                <section class="tienda-header mt32 pb16">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-12">
                                <h1 class="tienda-title">Nuestros productos</h1>
                                <p class="tienda-subtitle">Explora nuestra variedad de productos. Calidad profesional a tu alcance.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Grid de Productos -->
                <section class="pb64">
                    <div class="container">
                        <div t-if="not products" class="text-center py-5">
                            <h3 class="text-muted">No hay productos disponibles en este momento.</h3>
                            <p>Vuelve a visitarnos pronto o contáctanos directamente.</p>
                        </div>
                        
                        <div class="row g-4 pb-5" t-if="products">
                            <t t-foreach="products" t-as="product">
                                <!-- col-lg-4 para 3 columnas (12/3=4) -->
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="product-card">
                                        <!-- Imagen con contenedor controlado -->
                                        <div class="product-img-container">
                                            <span t-field="product.image_512" t-options="{'widget': 'image', 'preview_image': 'image_512', 'itemprop': 'image', 'class': 'd-block mx-auto'}"/>
                                        </div>
                                        
                                        <!-- Cuerpo de la tarjeta -->
                                        <div class="product-card-body">
                                            <h5 class="product-name" t-field="product.name"/>
                                            <p class="product-description" t-field="product.description_sale" t-options="{'widget': 'text'}"/>
                                            
                                            <div class="mt-auto">
                                                <button type="button" 
                                                        class="btn-whatsapp-catalog" 
                                                        t-att-data-product-name="product.name"
                                                        onclick="return window.contactWhatsApp(this)">
                                                    <i class="fa fa-whatsapp"/>
                                                    Solicitar Cotización
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>