            </div>

            <!-- SCRIPTS -->
            <!-- Los scripts han sido movidos a panel_web/static/src/js/panel.js -->
            <!-- Datos para los gráficos -->
            <script id="graficos_data_json" type="application/json" t-out="graficos_json"/>

        </t>

    </template>

</odoo>
