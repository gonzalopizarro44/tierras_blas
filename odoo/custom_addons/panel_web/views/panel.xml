<odoo>

    <template id="panel_template" name="Panel Administrativo">

        <t t-call="website.layout">

            <!-- Los estilos han sido movidos a panel_web/static/src/css/panel.css -->

            <div class="panel-page">
                <div class="container-lg">

                    <!-- HEADER -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                        <div>
                            <h1 class="panel-title">Panel Administrativo</h1>
                            <p class="panel-subtitle">Dashboard ejecutivo del negocio en tiempo real</p>
                        </div>
                    </div>

                    <!-- FILTROS -->
                    <div class="panel-card mb-4">
                        <form method="GET" action="/panel" class="row g-3">

                            <div class="col-md-3">
                                <label class="filter-label">Desde</label>
                                <input type="date" name="fecha_desde" class="form-control" t-att-value="fecha_desde"/>
                            </div>

                            <div class="col-md-3">
                                <label class="filter-label">Hasta</label>
                                <input type="date" name="fecha_hasta" class="form-control" t-att-value="fecha_hasta"/>
                            </div>

                            <div class="col-md-3">
                                <label class="filter-label">Categoría</label>
                                <select name="categoria" class="form-select">
                                    <option value="">-- Todas --</option>
                                    <t t-foreach="categorias" t-as="cat">
                                        <option t-att-value="cat.id" t-att-selected="str(cat.id) == categoria_id">
                                            <t t-esc="cat.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary w-100">🔍 Filtrar</button>
                                <a href="/panel" class="btn btn-outline-secondary">✕ Limpiar</a>
                            </div>

                        </form>
                    </div>

                    <!-- TABS -->
                    <div>
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="metricas-tab" data-bs-toggle="tab" data-bs-target="#metricas" type="button" role="tab">
                                    📈 Métricas
                                </button>
                            </li>
                            <!-- <li class="nav-item" role="presentation">
                                <button class="nav-link" id="indicadores-tab" data-bs-toggle="tab" data-bs-target="#indicadores" type="button" role="tab">
                                    📊 Indicadores
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="alertas-tab" data-bs-toggle="tab" data-bs-target="#alertas" type="button" role="tab">
                                    🚨 Alertas <span class="badge bg-danger ms-2" t-if="alertas" t-out="len(alertas)"/>
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="graficos-tab" data-bs-toggle="tab" data-bs-target="#graficos" type="button" role="tab">
                                    📉 Gráficos
                                </button>
                            </li> -->
                        </ul>

                        <!-- TAB CONTENT -->
                        <div class="tab-content mt-4">

                        <!-- TAB 1: MÉTRICAS -->
                        <div class="tab-pane fade show active" id="metricas" role="tabpanel">

                            <div class="row g-3 mb-4">

                                <!-- Total Ventas -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="total-ventas">
                                        <div class="metric-icon">📦</div>
                                        <div class="metric-value">
                                            <t t-esc="metricas['total_ventas']"/>
                                        </div>
                                        <div class="metric-label">Total de Ventas</div>
                                    </div>
                                </div>

                                <!-- Ingresos -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="ingresos">
                                        <div class="metric-icon">💵</div>
                                        <div class="metric-value">
                                            $<t t-esc="'%.0f' % metricas['ingresos']"/>
                                        </div>
                                        <div class="metric-label">Ingresos Totales</div>
                                    </div>
                                </div>

                                <!-- Total Compras -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="total-compras">
                                        <div class="metric-icon">🛒</div>
                                        <div class="metric-value">
                                            <t t-esc="metricas['total_compras']"/>
                                        </div>
                                        <div class="metric-label">Total de Compras</div>
                                    </div>
                                </div>

                                <!-- Gastos -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="gastos">
                                        <div class="metric-icon">💸</div>
                                        <div class="metric-value">
                                            $<t t-esc="'%.0f' % metricas['gastos']"/>
                                        </div>
                                        <div class="metric-label">Gastos Totales</div>
                                    </div>
                                </div>

                            </div>

                            <div class="row g-3 mb-4">

                                <!-- Ganancia Neta -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="ganancia-neta">
                                        <div class="metric-icon">
                                            <t t-if="metricas['ganancia_neta'] > 0">✅</t>
                                            <t t-else="">⚠️</t>
                                        </div>
                                        <div class="metric-value" t-att-style="'color: ' + ('#198754' if metricas['ganancia_neta'] > 0 else '#dc3545')">
                                            $<t t-esc="'%.0f' % metricas['ganancia_neta']"/>
                                        </div>
                                        <div class="metric-label">Ganancia Neta</div>
                                    </div>
                                </div>

                                <!-- Productos Activos -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="productos-activos">
                                        <div class="metric-icon">📋</div>
                                        <div class="metric-value">
                                            <t t-esc="metricas['productos_activos']"/>
                                        </div>
                                        <div class="metric-label">Productos Activos</div>
                                    </div>
                                </div>

                                <!-- Sin Stock -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="sin-stock" t-att-style="'background: ' + ('#f8d7da' if metricas['productos_sin_stock'] > 0 else '#d1f2eb')">
                                        <div class="metric-icon">❌</div>
                                        <div class="metric-value" t-att-style="'color: ' + ('#dc3545' if metricas['productos_sin_stock'] > 0 else '#198754')">
                                            <t t-esc="metricas['productos_sin_stock']"/>
                                        </div>
                                        <div class="metric-label">Sin Stock</div>
                                    </div>
                                </div>

                                <!-- Bajo Stock -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="metric-card" data-metric="bajo-stock" t-att-style="'background: ' + ('#fff8dc' if metricas['productos_bajo_stock'] > 0 else '#d1f2eb')">
                                        <div class="metric-icon">⚠️</div>
                                        <div class="metric-value" t-att-style="'color: ' + ('#ffc107' if metricas['productos_bajo_stock'] > 0 else '#198754')">
                                            <t t-esc="metricas['productos_bajo_stock']"/>
                                        </div>
                                        <div class="metric-label">Stock Bajo (&lt;10)</div>
                                    </div>
                                </div>

                            </div>

                        </div>

