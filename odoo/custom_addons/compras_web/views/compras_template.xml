<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="compras_template" name="Panel de Compras">

        <t t-call="website.layout">

            <!-- ESTILOS PERSONALIZADOS -->
            <style>
                :root {
                    --brand-primary: #166534;
                    --brand-primary-dark: #0f4620;
                    --brand-light: #dcfce7;
                    --brand-secondary: #6b7280;
                    --brand-bg: #f9fafb;
                    --brand-card: #ffffff;
                    --brand-border: #e5e7eb;
                    --brand-text: #1f2937;
                    --brand-text-muted: #6b7280;
                    --brand-shadow: 0 1px 3px rgba(0,0,0,.08);
                    --brand-radius: 0.75rem;
                }

                .compras-page {
                    background: var(--brand-bg);
                    min-height: 100vh;
                    padding: 2rem 0;
                    font-family: 'Inter', sans-serif;
                }

                .compras-card {
                    background: var(--brand-card);
                    border-radius: var(--brand-radius);
                    box-shadow: var(--brand-shadow);
                    border: 1px solid var(--brand-border);
                    padding: 1.5rem;
                    margin-bottom: 1.5rem;
                    transition: box-shadow 0.3s ease;
                }

                .compras-card:hover {
                    box-shadow: 0 4px 6px rgba(0,0,0,.1);
                }

                .compras-title {
                    font-size: 1.75rem;
                    font-weight: 700;
                    color: var(--brand-text);
                    margin: 0;
                    font-family: 'Inter', sans-serif;
                }

                .compras-subtitle {
                    font-size: 0.9rem;
                    color: var(--brand-text-muted);
                    margin-top: 0.25rem;
                }

                .compras-stat {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.5rem;
                    padding: 0.5rem 1rem;
                    background: var(--brand-light);
                    border-radius: var(--brand-radius);
                    color: var(--brand-primary);
                    font-weight: 600;
                    font-size: 0.875rem;
                }

                .compras-badge {
                    display: inline-block;
                    padding: 0.25em 0.65em;
                    border-radius: 999px;
                    font-size: 0.75rem;
                    font-weight: 600;
                }

                .badge-draft { background: #fef3c7; color: #78350f; }
                .badge-purchase { background: var(--brand-light); color: var(--brand-primary); }
                .badge-cancel { background: #fee2e2; color: #7f1d1d; }

                .compras-table thead th {
                    background: var(--brand-bg);
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.03em;
                    color: var(--brand-text-muted);
                    font-size: 0.8rem;
                    border-color: var(--brand-border);
                    padding: 1rem 0.75rem;
                    border-bottom: 2px solid var(--brand-border);
                }

                .compras-table tbody td {
                    padding: 0.75rem;
                    border-color: var(--brand-border);
                    vertical-align: middle;
                    color: var(--brand-text);
                    font-size: 0.9rem;
                }

                .compras-table tbody tr:hover {
                    background: var(--brand-bg);
                }

                .compras-btn-primary {
                    background: var(--brand-primary);
                    border: none;
                    color: white;
                    padding: 0.5rem 1rem;
                    font-weight: 600;
                    font-size: 0.875rem;
                    border-radius: var(--brand-radius);
                    transition: all 0.2s;
                    font-family: 'Inter', sans-serif;
                    cursor: pointer;
                }

                .compras-btn-primary:hover {
                    background: var(--brand-primary-dark);
                    color: white;
                    text-decoration: none;
                    transform: translateY(-1px);
                }

                .compras-btn-sm {
                    padding: 0.35rem 0.65rem;
                    font-size: 0.8rem;
                    margin: 0 0.25rem;
                }

                .compras-btn-success {
                    background: #22c55e;
                    color: white;
                }

                .compras-btn-success:hover {
                    background: #16a34a;
                    color: white;
                    transform: translateY(-1px);
                }

                .compras-btn-danger {
                    background: #f87171;
                    color: white;
                }

                .compras-btn-danger:hover {
                    background: #ef4444;
                    color: white;
                    transform: translateY(-1px);
                }

                .compras-filter-label {
                    font-size: 0.8rem;
                    font-weight: 600;
                    color: var(--brand-text-muted);
                    text-transform: uppercase;
                    letter-spacing: 0.025em;
                    margin-bottom: 0.35rem;
                }

                .form-control, .form-select {
                    border-color: var(--brand-border);
                    border-radius: var(--brand-radius);
                }

                .form-control:focus, .form-select:focus {
                    border-color: var(--brand-primary);
                    box-shadow: 0 0 0 0.2rem rgba(22,101,52,.15);
                }

                .compras-empty {
                    text-align: center;
                    padding: 3rem 1rem;
                    color: var(--brand-text-muted);
                }

                .compras-empty i {
                    font-size: 3rem;
                    margin-bottom: 1rem;
                    display: block;
                    color: #adb5bd;
                }
            </style>

            <div class="compras-page">
                <div class="container-lg">

                    <!-- HEADER -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                        <div>
                            <h1 class="compras-title">Panel de Compras</h1>
                            <p class="compras-subtitle">Gestión integral de órdenes de compra</p>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <div class="compras-stat">
                                <strong>Total:</strong>
                                <t t-esc="total_compras"/>
                            </div>
                            <a href="/compras/nueva" class="btn compras-btn-primary">
                                ➕ Registrar Nueva Compra
                            </a>
                        </div>
                    </div>

                    <!-- FILTROS AVANZADOS -->
                    <div class="compras-card">
                        <form method="GET" action="/compras" class="row g-3 align-items-end">

                            <!-- Proveedor -->
                            <div class="col-12 col-md-6 col-lg-2">
                                <label class="compras-filter-label">Proveedor</label>
                                <input type="text" name="proveedor" class="form-control form-control-sm"
                                       placeholder="Nombre..."
                                       t-att-value="filtros.get('proveedor', '')"/>
                            </div>

                            <!-- Producto -->
                            <div class="col-12 col-md-6 col-lg-2">
                                <label class="compras-filter-label">Producto</label>
                                <input type="text" name="producto" class="form-control form-control-sm"
                                       placeholder="Nombre..."
                                       t-att-value="filtros.get('producto', '')"/>
                            </div>

                            <!-- Categoría -->
                            <div class="col-12 col-md-6 col-lg-2">
                                <label class="compras-filter-label">Categoría</label>
                                <select name="categoria" class="form-select form-select-sm">
                                    <option value="">Todas</option>
                                    <t t-foreach="categorias" t-as="cat">
                                        <option t-att-value="cat.id"
                                                t-att-selected="str(cat.id) == filtros.get('categoria', '')">
                                            <t t-esc="cat.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <!-- Estado -->
                            <div class="col-12 col-md-6 col-lg-2">
                                <label class="compras-filter-label">Estado</label>
                                <select name="estado" class="form-select form-select-sm">
                                    <option value="">Todos</option>
                                    <option value="draft" t-att-selected="filtros.get('estado', '') == 'draft'">Pedido</option>
                                    <option value="purchase" t-att-selected="filtros.get('estado', '') == 'purchase'">Confirmado</option>
                                    <option value="cancel" t-att-selected="filtros.get('estado', '') == 'cancel'">Cancelado</option>
                                </select>
                            </div>

                            <!-- Botones -->
                            <div class="col-12 col-lg-auto d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary">🔍 Filtrar</button>
                                <a href="/compras" class="btn btn-sm btn-outline-secondary">✕ Limpiar</a>
                            </div>

                        </form>
                    </div>

                    <!-- TABLA DE COMPRAS -->
                    <div class="compras-card" style="overflow: hidden; padding: 0;">

                        <t t-if="compras">
                            <div class="table-responsive">
                                <table class="table compras-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Orden</th>
                                            <th>Proveedor</th>
                                            <th>Productos</th>
                                            <th>Cantidad</th>
                                            <th>Total</th>
                                            <th>Estado</th>
                                            <th>Fecha</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="compras" t-as="compra">
                                            <tr>
                                                <!-- Número de orden -->
                                                <td style="font-weight: 600;">
                                                    <t t-esc="compra.name"/>
                                                </td>

                                                <!-- Proveedor -->
                                                <td>
                                                    <t t-esc="compra.partner_id.name"/>
                                                </td>

                                                <!-- Productos (resumen) -->
                                                <td>
                                                    <t t-foreach="compra.order_line" t-as="linea">
                                                        <small><t t-esc="linea.product_id.name"/></small><br/>
                                                    </t>
                                                </td>

                                                <!-- Cantidad total -->
                                                <td>
                                                    <t t-set="cant_total" t-value="sum(compra.order_line.mapped('product_qty'))"/>
                                                    <t t-esc="'%.2f' % cant_total"/>
                                                </td>

                                                <!-- Total (monto) -->
                                                <td style="font-weight: 600;">
                                                    $ <t t-esc="'%.2f' % compra.amount_total"/>
                                                </td>

                                                <!-- Estado (badge) -->
                                                <td>
                                                    <t t-if="compra.state == 'draft'">
                                                        <span class="compras-badge badge-draft">📋 Pedido</span>
                                                    </t>
                                                    <t t-elif="compra.state == 'purchase'">
                                                        <span class="compras-badge badge-purchase">✓ Confirmado</span>
                                                    </t>
                                                    <t t-elif="compra.state == 'cancel'">
                                                        <span class="compras-badge badge-cancel">✕ Cancelado</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="compras-badge badge-draft"><t t-esc="compra.state"/></span>
                                                    </t>
                                                </td>

                                                <!-- Fecha -->
                                                <td>
                                                    <small><t t-esc="compra.date_order.strftime('%d/%m/%Y %H:%M')"/></small>
                                                </td>

                                                <!-- Acciones -->
                                                <td>
                                                    <t t-if="compra.state == 'draft'">
                                                        <button type="button" class="btn compras-btn-sm compras-btn-success"
                                                                onclick="confirmarCompra(this)" t-att-data-order-id="compra.id">
                                                            ✓ Confirmar
                                                        </button>
                                                        <button type="button" class="btn compras-btn-sm compras-btn-danger"
                                                                onclick="cancelarCompra(this)" t-att-data-order-id="compra.id">
                                                            ✕ Cancelar
                                                        </button>
                                                    </t>
                                                    <t t-elif="compra.state == 'purchase'">
                                                        <button type="button" class="btn compras-btn-sm compras-btn-success"
                                                                onclick="validarRecepcion(this)" t-att-data-order-id="compra.id">
                                                            ✓ Validar
                                                        </button>
                                                        <button type="button" class="btn compras-btn-sm compras-btn-danger"
                                                                onclick="cancelarCompra(this)" t-att-data-order-id="compra.id">
                                                            ✕ Cancelar
                                                        </button>
                                                    </t>
                                                    <t t-elif="compra.state == 'done'">
                                                        <button type="button" class="btn compras-btn-sm btn-secondary" disabled="disabled">
                                                            ✓ Completado
                                                        </button>
                                                    </t>
                                                    <t t-elif="compra.state == 'cancel'">
                                                        <span style="font-size: 0.8rem; color: #999;">Cancelado</span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Estado vacío -->
                        <t t-else="">
                            <div class="compras-empty">
                                <i>🔭</i>
                                <h5>No se encontraron compras</h5>
                                <p class="mb-0">Intenta ajustar los filtros o <a href="/compras">limpiar la búsqueda</a>.</p>
                            </div>
                        </t>

                    </div>

                </div>
            </div>

            <!-- JAVASCRIPT -->
            <script type="text/javascript">
                function confirmarCompra(btn) {
                    const ordenId = btn.getAttribute('data-order-id');
                    const txtBtn = btn.innerText;

                    if (!confirm('¿Confirmar esta compra? El stock se incrementará.')) return;

                    btn.disabled = true;
                    btn.innerHTML = '⏳ Procesando...';

                    fetch('/compras/confirmar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            jsonrpc: "2.0",
                            method: "call",
                            params: { orden_id: parseInt(ordenId) }
                        })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.result &amp;&amp; data.result.success) {
                            alert(data.result.message);
                            location.reload();
                        } else {
                            alert('Error: ' + (data.result ? data.result.message : 'Unknown'));
                            btn.disabled = false;
                            btn.innerText = txtBtn;
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Error de conexión');
                        btn.disabled = false;
                        btn.innerText = txtBtn;
                    });
                }

                function cancelarCompra(btn) {
                    const ordenId = btn.getAttribute('data-order-id');
                    const txtBtn = btn.innerText;

                    if (!confirm('¿Cancelar esta compra? El stock NO será modificado.')) return;

                    btn.disabled = true;
                    btn.innerHTML = '⏳ Procesando...';

                    fetch('/compras/cancelar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            jsonrpc: "2.0",
                            method: "call",
                            params: { orden_id: parseInt(ordenId) }
                        })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.result &amp;&amp; data.result.success) {
                            alert(data.result.message);
                            location.reload();
                        } else {
                            alert('Error: ' + (data.result ? data.result.message : 'Unknown'));
                            btn.disabled = false;
                            btn.innerText = txtBtn;
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Error de conexión');
                        btn.disabled = false;
                        btn.innerText = txtBtn;
                    });
                }

                function validarRecepcion(btn) {
                    const ordenId = btn.getAttribute('data-order-id');
                    const txtBtn = btn.innerText;

                    if (!confirm('¿Validar esta recepción? El stock se incrementará automáticamente.')) return;

                    btn.disabled = true;
                    btn.innerHTML = '⏳ Procesando...';

                    fetch('/compras/validar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            jsonrpc: "2.0",
                            method: "call",
                            params: { orden_id: parseInt(ordenId) }
                        })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.result &amp;&amp; data.result.success) {
                            alert(data.result.message);
                            location.reload();
                        } else {
                            alert('Error: ' + (data.result ? data.result.message : 'Unknown'));
                            btn.disabled = false;
                            btn.innerText = txtBtn;
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Error de conexión');
                        btn.disabled = false;
                        btn.innerText = txtBtn;
                    });
                }
            </script>

        </t>
    </template>
</odoo>
