<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tienda_web_products_item_catalog" inherit_id="website_sale.products_item">
        <xpath expr="//div[hasclass('product_price')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('o_wsale_product_btn')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('o_wsale_product_information')]" position="inside">
            <div class="d-flex justify-content-center mt-2 px-2 pb-2">
                <button type="button" class="btn btn-whatsapp-premium w-100" onclick="consultarWhatsApp(this)" t-att-data-product-name="product.name">
                    <i class="fa fa-whatsapp me-1"/>
                    <span class="small">Consultar WhatsApp</span>
                </button>
            </div>
        </xpath>
    </template>

    <template id="tienda_web_product_catalog" inherit_id="website_sale.product">
        <xpath expr="//div[@id='product_details']//t[@t-call='website_sale.product_price']" position="replace"/>
        <xpath expr="//div[@id='product_details']//form[@action='/shop/cart/update']" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
        <xpath expr="//div[@id='product_details']//form[@action='/shop/cart/update']" position="after">
            <div class="mt-4">
                <a id="solicitar_whatsapp_detail" role="button" href="#" onclick="return consultarWhatsAppDetail(event)" class="btn btn-whatsapp-premium btn-lg w-100 animate-pulse-whatsapp d-flex align-items-center justify-content-center" t-att-data-product-name="product.name">
                    <i class="fa fa-whatsapp fa-2x me-2"/>
                    <div class="text-start">
                        <span class="d-block fw-bold">Consultar por WhatsApp</span>
                        <small class="d-block opacity-75">Respuesta inmediata</small>
                    </div>
                </a>
            </div>
        </xpath>
    </template>

    <template id="tienda_web_hide_wishlist" inherit_id="website_sale_wishlist.product_add_to_wishlist">
        <xpath expr="//a[hasclass('o_add_wishlist')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
    </template>

    <template id="tienda_web_hide_quick_reorder" inherit_id="website_sale.quick_reorder_button" optional="enabled">
        <xpath expr="//button" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
    </template>
</odoo>
