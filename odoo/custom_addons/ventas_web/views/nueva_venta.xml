<odoo>
    <template id="nueva_venta_template" name="Registrar Nueva Venta">

        <t t-call="website.layout">

            <!-- ESTILOS -->
            <style>
                :root {
                    --brand-primary: #166534;
                    --brand-primary-dark: #0f4620;
                    --brand-light: #dcfce7;
                    --brand-secondary: #6b7280;
                    --brand-bg: #f9fafb;
                    --brand-border: #e5e7eb;
                    --brand-text: #1f2937;
                    --brand-text-muted: #6b7280;
                    --brand-shadow: 0 1px 3px rgba(0,0,0,.08);
                    --brand-radius: 0.75rem;
                }

                .nv-page { background: var(--brand-bg); min-height: 100vh; padding: 2rem 0; font-family: 'Inter', sans-serif; }

                .nv-card {
                    background: white;
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    padding: 2rem;
                    box-shadow: var(--brand-shadow);
                    margin-bottom: 2rem;
                    transition: box-shadow 0.3s ease;
                }

                .nv-card:hover {
                    box-shadow: 0 4px 6px rgba(0,0,0,.1);
                }

                .nv-title { 
                    font-size: 1.5rem; 
                    font-weight: 700; 
                    margin: 0;
                    color: var(--brand-text);
                    font-family: 'Inter', sans-serif;
                }

                .nv-section-title {
                    font-size: 1rem;
                    font-weight: 600;
                    color: var(--brand-primary);
                    border-bottom: 2px solid var(--brand-border);
                    padding-bottom: 0.75rem;
                    margin-bottom: 1rem;
                }

                .nv-label {
                    font-weight: 600;
                    font-size: 0.9rem;
                    margin-bottom: 0.5rem;
                    color: var(--brand-text);
                }

                .nv-linea {
                    background: var(--brand-bg);
                    border: 1px solid var(--brand-border);
                    border-radius: var(--brand-radius);
                    padding: 1rem;
                    margin-bottom: 1rem;
                    position: relative;
                }

                .nv-linea-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    margin-bottom: 0.75rem;
                    padding-bottom: 0.75rem;
                    border-bottom: 1px solid var(--brand-border);
                }

                .nv-linea-producto {
                    font-weight: 600;
                    color: var(--brand-primary);
                }

                .nv-linea-close {
                    cursor: pointer;
                    color: #f87171;
                    font-weight: bold;
                    font-size: 1.2rem;
                }

                .nv-linea-close:hover {
                    opacity: 0.7;
                }

                .nv-linea-totales {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 1rem;
                    margin-top: 0.75rem;
                    padding-top: 0.75rem;
                    border-top: 1px dotted var(--brand-border);
                }

                .nv-linea-total-item {
                    text-align: center;
                }

                .nv-linea-total-label {
                    font-size: 0.75rem;
                    color: var(--brand-text-muted);
                    text-transform: uppercase;
                    font-weight: 600;
                }

                .nv-linea-total-value {
                    font-size: 1.1rem;
                    font-weight: 700;
                    color: var(--brand-primary);
                }

                .nv-btn {
                    display: inline-block;
                    padding: 0.5rem 1rem;
                    border: none;
                    border-radius: var(--brand-radius);
                    font-weight: 600;
                    font-size: 0.875rem;
                    cursor: pointer;
                    transition: all 0.2s;
                    text-align: center;
                    text-decoration: none;
                    font-family: 'Inter', sans-serif;
                }

                .nv-btn-primary {
                    background: var(--brand-primary);
                    color: white;
                }

                .nv-btn-primary:hover {
                    background: var(--brand-primary-dark);
                    color: white;
                    transform: translateY(-1px);
                }

                .nv-btn-success {
                    background: #22c55e;
                    color: white;
                }

                .nv-btn-success:hover {
                    background: #16a34a;
                    color: white;
                    transform: translateY(-1px);
                }

                .nv-btn-secondary {
                    background: #6b7280;
                    color: white;
                }

                .nv-btn-secondary:hover {
                    background: #4b5563;
                    color: white;
                    transform: translateY(-1px);
                }

                .nv-btn-sm {
                    padding: 0.35rem 0.65rem;
                    font-size: 0.8rem;
                }

                .nv-btn-block {
                    width: 100%;
                }

                .nv-resumen {
                    background: var(--brand-light);
                    border-left: 4px solid var(--brand-primary);
                    padding: 1rem;
                    border-radius: 0 var(--brand-radius) var(--brand-radius) 0;
                    margin-bottom: 1rem;
                }

                .nv-resumen-item {
                    display: flex;
                    justify-content: space-between;
                    margin-bottom: 0.5rem;
                    font-size: 0.95rem;
                    color: var(--brand-text);
                }

                .nv-resumen-item:last-child {
                    margin-bottom: 0;
                    border-top: 1px solid rgba(22,101,52,.3);
                    padding-top: 0.5rem;
                    font-size: 1.1rem;
                    font-weight: 700;
                    color: var(--brand-primary);
                }

                .nv-cliente-nuevo {
                    background: #fef3c7;
                    border: 1px dashed #fbbf24;
                    border-radius: var(--brand-radius);
                    padding: 1rem;
                    margin-top: 0.5rem;
                }

                .nv-alert {
                    padding: 1rem;
                    border-radius: var(--brand-radius);
                    margin-bottom: 1rem;
                }

                .nv-alert-info {
                    background: var(--brand-light);
                    color: var(--brand-primary);
                    border-left: 4px solid var(--brand-primary);
                }

                .nv-alert-success {
                    background: #d1e7dd;
                    color: #0f3622;
                    border-left: 4px solid #22c55e;
                }

                .nv-alert-error {
                    background: #fee2e2;
                    color: #842029;
                    border-left: 4px solid #f87171;
                }

                .form-control:focus, .form-select:focus {
                    border-color: var(--brand-primary);
                    box-shadow: 0 0 0 0.2rem rgba(22,101,52,.15);
                }

                .nv-spinner {
                    display: inline-block;
                    width: 1rem;
                    height: 1rem;
                    border: 2px solid rgba(255,255,255,.3);
                    border-radius: 50%;
                    border-top-color: white;
                    animation: spin 0.6s linear infinite;
                }

                @keyframes spin {
                    to { transform: rotate(360deg); }
                }

                .nv-formulario-dos-columnas {
                    display: grid;
                    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                    gap: 1rem;
                }
            </style>

            <div class="nv-page">
                <div class="container">

                    <!-- HEADER -->
                    <div class="mb-4">
                        <a href="/ventas" class="text-muted" style="text-decoration: none;">← Volver al Panel</a>
                        <h1 class="nv-title mt-2">Registrar Nueva Venta</h1>
                    </div>

                    <!-- SECCIÓN 1: CLIENTE -->
                    <div class="nv-card">
                        <h3 class="nv-section-title">1. Seleccionar Cliente</h3>

                        <div class="row">
                            <div class="col-md-8">
                                <label class="nv-label">Cliente Existente</label>
                                <select id="clienteSelect" class="form-select form-select-lg" onchange="clienteSeleccionado()">
                                    <option value="">-- Seleccionar cliente --</option>
                                    <t t-foreach="clientes" t-as="c">
                                        <option t-att-value="c.id">
                                            <t t-esc="c.name"/>
                                            <t t-if="c.vat"> (<t t-esc="c.vat"/>)</t>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="nv-label">&amp;nbsp;</label>
                                <button type="button" class="btn btn-outline-primary w-100" data-bs-toggle="collapse" data-bs-target="#nuevoClienteForm">
                                    ➕ Crear Nuevo Cliente
                                </button>
                            </div>
                        </div>

                        <!-- Formulario de nuevo cliente (contraído) -->
                        <div class="collapse mt-3" id="nuevoClienteForm">
                            <div class="nv-cliente-nuevo">
                                <h5 style="margin-bottom: 1rem;">Crear Nuevo Cliente</h5>
                                <div class="nv-formulario-dos-columnas">
                                    <div>
                                        <label class="nv-label">Nombre Completo</label>
                                        <input type="text" id="nuevoClienteNombre" class="form-control" placeholder="Juan Pérez"/>
                                    </div>
                                    <div>
                                        <label class="nv-label">DNI (Opcional)</label>
                                        <input type="text" id="nuevoClienteDNI" class="form-control" placeholder="12345678"/>
                                    </div>
                                </div>
                                <button type="button" class="btn nv-btn nv-btn-primary mt-3 w-100" onclick="crearClienteRapido()">
                                    Crear Cliente
                                </button>
                            </div>
                        </div>

                        <!-- Cliente seleccionado (info) -->
                        <div id="clienteInfo" style="display: none; margin-top: 1.5rem; padding: 1rem; background: #d1e7dd; border-radius: var(--brand-radius); color: #0f3622;">
                            Cliente seleccionado: <strong id="clienteInfoNombre"></strong>
                        </div>

                    </div>

                    <!-- SECCIÓN 2: PRODUCTOS -->
                    <div class="nv-card">
                        <h3 class="nv-section-title">2. Agregar Productos</h3>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="nv-label">Producto</label>
                                <select id="productoSelect" class="form-select">
                                    <option value="">-- Seleccionar producto --</option>
                                    <t t-foreach="productos" t-as="prod">
                                        <option t-att-value="prod['id']" t-att-data-price="prod['list_price']" t-att-data-stock="prod['free_qty']" t-att-data-is-service="1 if prod['is_service'] else 0">
                                            <t t-esc="prod['display_name']"/> - $<t t-esc="'%.2f' % prod['list_price']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="nv-label">Cantidad</label>
                                <input type="number" id="productoCantidad" class="form-control" placeholder="1" value="1" min="1" step="0.01"/>
                            </div>

                            <div class="col-md-3">
                                <label class="nv-label">&amp;nbsp;</label>
                                <button type="button" class="btn btn-primary w-100" onclick="agregarProducto()">
                                    ➕ Agregar
                                </button>
                            </div>
                        </div>

                        <!-- Líneas de productos agregados -->
                        <div id="lineasProductos">
                            <p class="text-muted text-center py-4">No hay productos agregados aún</p>
                        </div>

                    </div>

                    <!-- SECCIÓN 3: MÉTODO DE PAGO -->
                    <div class="nv-card">
                        <h3 class="nv-section-title">3. Método de Pago</h3>

                        <div class="row">
                            <div class="col-md-6">
                                <label class="nv-label">Seleccionar Método</label>
                                <select id="paymentMethodSelect" class="form-select">
                                    <option value="">-- Sin especificar --</option>
                                    <t t-foreach="journals" t-as="j">
                                        <option t-att-value="j.id">
                                            <t t-esc="j.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>

                    </div>

                    <!-- SECCIÓN 4: RESUMEN Y CONFIRMACIÓN -->
                    <div class="nv-card">
                        <h3 class="nv-section-title">4. Resumen y Guardar</h3>

                        <!-- Resumen de totales -->
                        <div class="nv-resumen" id="resumenTotales" style="display: none;">
                            <div class="nv-resumen-item">
                                <span>Cantidad de productos:</span>
                                <strong id="resumenCantProductos">0</strong>
                            </div>
                            <div class="nv-resumen-item">
                                <span>Cantidad total:</span>
                                <strong id="resumenCantTotal">0</strong>
                            </div>
                            <div class="nv-resumen-item">
                                <span>Total a Pagar:</span>
                                <strong id="resumenTotal">$0.00</strong>
                            </div>
                        </div>

                        <!-- Botones de acción -->
                        <div class="d-flex gap-2">
                            <button type="button" class="btn nv-btn nv-btn-success nv-btn-lg" onclick="guardarVenta()" style="flex: 1; padding: 0.75rem;">
                                ✓ Registrar y Confirmar Venta
                            </button>
                            <a href="/ventas" class="btn nv-btn nv-btn-secondary" style="padding: 0.75rem;">
                                ← Cancelar
                            </a>
                        </div>

                    </div>

                </div>
            </div>

            <!-- JAVASCRIPT -->
            <script type="text/javascript">

                // Estado interno de la venta
                let ventaData = {
                    cliente_id: null,
                    lineas: [],
                    journal_id: null
                };

                // Productos disponibles (para búsqueda rápida)
                const productosData = [
                    <t t-foreach="productos" t-as="prod">
                        { id: <t t-esc="prod['id']"/>, name: "<t t-esc="prod['name'].replace('&quot;', '\\&quot;')"/>", price: <t t-esc="prod['list_price']"/>, stock: <t t-esc="prod['free_qty']"/>, isService: <t t-esc="1 if prod['is_service'] else 0"/> },
                    </t>
                ];

                function clienteSeleccionado() {
                    const select = document.getElementById('clienteSelect');
                    const clienteId = select.value;

                    if (clienteId) {
                        ventaData.cliente_id = parseInt(clienteId);
                        document.getElementById('clienteInfo').style.display = 'block';
                        document.getElementById('clienteInfoNombre').innerText = select.options[select.selectedIndex].text;
                    } else {
                        ventaData.cliente_id = null;
                        document.getElementById('clienteInfo').style.display = 'none';
                    }

                    actualizarResumen();
                }

                function crearClienteRapido() {
                    const nombre = document.getElementById('nuevoClienteNombre').value.trim();
                    const dni = document.getElementById('nuevoClienteDNI').value.trim();

                    if (!nombre) {
                        alert('Ingresa el nombre del cliente');
                        return;
                    }

                    fetch('/ventas/crear_cliente', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            jsonrpc: "2.0",
                            method: "call",
                            params: { nombre: nombre, dni: dni }
                        })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.result &amp;&amp; data.result.success) {
                            // Agregar nuevo cliente al select
                            const select = document.getElementById('clienteSelect');
                            const option = document.createElement('option');
                            option.value = data.result.id;
                            option.text = data.result.nombre;
                            select.appendChild(option);
                            select.value = data.result.id;

                            // Limpiar formulario
                            document.getElementById('nuevoClienteNombre').value = '';
                            document.getElementById('nuevoClienteDNI').value = '';
                            document.getElementById('nuevoClienteForm').classList.remove('show');

                            clienteSeleccionado();
                            alert(data.result.message);
                        } else {
                            alert('Error: ' + (data.result ? data.result.message : 'Unknown'));
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Error de conexión');
                    });
                }

                function agregarProducto() {
                    const select = document.getElementById('productoSelect');
                    const cantidad = parseFloat(document.getElementById('productoCantidad').value);

                    if (!select.value) {
                        alert('Selecciona un producto');
                        return;
                    }

                    if (cantidad &lt;= 0) {
                        alert('La cantidad debe ser mayor a 0');
                        return;
                    }

                    const productId = parseInt(select.value);
                    const producto = productosData.find(p => p.id === productId);

                    if (!producto) {
                        alert('Producto no encontrado');
                        return;
                    }

                    // ╔════════════════════════════════════════════════════════════╗
                    // ║ VALIDACIÓN DE STOCK - BLINDAJE CONTRA SOBREVENTA          ║
                    // ╚════════════════════════════════════════════════════════════╝
                    if (!producto.isService) {
                        // Solo validar stock si NO es un servicio
                        const stockDisponible = parseFloat(select.options[select.selectedIndex].getAttribute('data-stock')) || 0;
                        
                        if (cantidad &gt; stockDisponible) {
                            alert('La cantidad a vender debe ser igual o menor a ' + stockDisponible.toFixed(0) + ' u.');
                            return;
                        }
                    }

                    // Crear línea
                    const linea = {
                        id: Date.now(),
                        product_id: producto.id,
                        product_name: producto.name,
                        quantity: cantidad,
                        price_unit: producto.price,
                        subtotal: cantidad * producto.price
                    };

                    ventaData.lineas.push(linea);

                    // Limpiar selects
                    select.value = '';
                    document.getElementById('productoCantidad').value = '1';

                    actualizarVistaLineas();
                    actualizarResumen();
                }

                function eliminarLinea(id) {
                    ventaData.lineas = ventaData.lineas.filter(l => l.id !== id);
                    actualizarVistaLineas();
                    actualizarResumen();
                }

                function actualizarVistaLineas() {
                    const container = document.getElementById('lineasProductos');

                    if (ventaData.lineas.length === 0) {
                        container.innerHTML = '&lt;p class="text-muted text-center py-4"&gt;No hay productos agregados aún&lt;/p&gt;';
                        return;
                    }

                    container.innerHTML = ventaData.lineas.map(linea => `
                        &lt;div class="nv-linea"&gt;
                            &lt;div class="nv-linea-header"&gt;
                                &lt;div class="nv-linea-producto"&gt;${linea.product_name}&lt;/div&gt;
                                &lt;div class="nv-linea-close" onclick="eliminarLinea(${linea.id})"&gt;✕&lt;/div&gt;
                            &lt;/div&gt;
                            &lt;div class="nv-linea-totales"&gt;
                                &lt;div class="nv-linea-total-item"&gt;
                                    &lt;div class="nv-linea-total-label"&gt;Cantidad&lt;/div&gt;
                                    &lt;div class="nv-linea-total-value"&gt;${linea.quantity.toFixed(2)}&lt;/div&gt;
                                &lt;/div&gt;
                                &lt;div class="nv-linea-total-item"&gt;
                                    &lt;div class="nv-linea-total-label"&gt;Precio Unit.&lt;/div&gt;
                                    &lt;div class="nv-linea-total-value"&gt;$${linea.price_unit.toFixed(2)}&lt;/div&gt;
                                &lt;/div&gt;
                                &lt;div class="nv-linea-total-item"&gt;
                                    &lt;div class="nv-linea-total-label"&gt;Subtotal&lt;/div&gt;
                                    &lt;div class="nv-linea-total-value"&gt;$${linea.subtotal.toFixed(2)}&lt;/div&gt;
                                &lt;/div&gt;
                            &lt;/div&gt;
                        &lt;/div&gt;
                    `).join('');
                }

                function actualizarResumen() {
                    const cantProductos = ventaData.lineas.length;
                    const cantTotal = ventaData.lineas.reduce((sum, l) => sum + l.quantity, 0);
                    const total = ventaData.lineas.reduce((sum, l) => sum + l.subtotal, 0);

                    document.getElementById('resumenCantProductos').innerText = cantProductos;
                    document.getElementById('resumenCantTotal').innerText = cantTotal.toFixed(2);
                    document.getElementById('resumenTotal').innerText = '$' + total.toFixed(2);

                    const resumen = document.getElementById('resumenTotales');
                    if (cantProductos > 0) {
                        resumen.style.display = 'block';
                    } else {
                        resumen.style.display = 'none';
                    }
                }

                function guardarVenta() {
                    // Validaciones
                    if (!ventaData.cliente_id) {
                        alert('Selecciona un cliente');
                        return;
                    }

                    if (ventaData.lineas.length === 0) {
                        alert('Agrega al menos un producto');
                        return;
                    }

                    const btn = event.target;
                    const txtBtn = btn.innerText;
                    btn.disabled = true;
                    btn.innerHTML = '&lt;span class="nv-spinner" style="margin-right: 0.5rem;"&gt;&lt;/span&gt; Procesando...';

                    // Convertir lineas al formato esperado
                    const lineas = ventaData.lineas.map(l => ({
                        product_id: l.product_id,
                        quantity: l.quantity
                    }));

                    // Llamada AJAX
                    fetch('/ventas/crear', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            jsonrpc: "2.0",
                            method: "call",
                            params: {
                                cliente_id: ventaData.cliente_id,
                                lineas: lineas,
                                origen: 'admin',
                                journal_id: ventaData.journal_id
                            }
                        })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.result &amp;&amp; data.result.success) {
                            alert(data.result.message);
                            window.location.href = data.result.url || '/ventas';
                        } else {
                            alert('Error: ' + (data.result ? data.result.message : 'Unknown'));
                            btn.disabled = false;
                            btn.innerText = txtBtn;
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Error de conexión');
                        btn.disabled = false;
                        btn.innerText = txtBtn;
                    });
                }

                // Inicializar resumen
                actualizarResumen();

                // Escucha cambios en el método de pago
                document.getElementById('paymentMethodSelect').addEventListener('change', function() {
                    ventaData.journal_id = this.value ? parseInt(this.value) : null;
                });

            </script>

        </t>

    </template>

</odoo>